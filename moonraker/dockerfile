# Dockerfile para Moonraker
FROM python:3.9-slim

# Instala dependęncias necessárias
RUN apt-get update && apt-get install -y \
    git \
    libffi-dev \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Define diretório de trabalho
WORKDIR /app

# Clona o repositório oficial do Moonraker
RUN git clone https://github.com/Arksine/moonraker.git .

# Instala dependęncias Python
RUN pip install --no-cache-dir -r requirements.txt

# Porta padrăo da API
EXPOSE 7125

# Comando de inicializaçăo
CMD ["python3", "moonraker/moonraker.py", "-c", "/home/pi/klipper_config/moonraker.conf"]
